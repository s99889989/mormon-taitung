    const dateString = `${year}-${month}`;

    const url = data.main_url+'mormon/roll_call/get_date';
    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: dateString
      });
      roll_call_list =  await response.json();
    } catch (error) {
      roll_call_list =  [];
