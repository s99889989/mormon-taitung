              <option>所有</option>
              <option>有到</option>
              <option>沒到</option>
            </select>
          </div>
        </div>

        <!-- 人員列表：點擊整張卡片切換狀態 -->
        <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(200px, 1fr))">
          <div v-for="(member) in searchMemberList" :key="member.id"
               :class="member.have
              ? 'dark:bg-gray-900 bg-gray-50 border-blue-400 dark:border-blue-500'
