  }

  //刷新列表 該年 該月
  const refreshRollCallCurrentMonth = async () => {
    let roll_call_list= [
      {
        date: '',
        roll_call_man: '',
        member_list: [],
        member_visit_list: [],
      },
    ];

    const today = new Date();
    const year = today.getFullYear();
